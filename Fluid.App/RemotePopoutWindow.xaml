<Window x:Class="Fluid.App.RemotePopoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:Fluid.App.Models"
        xmlns:local="clr-namespace:Fluid.App"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="12" Padding="6"
            MouseLeftButtonDown="OnDragMouseDown"
            MouseMove="OnDragMouseMove"
            MouseLeftButtonUp="OnDragMouseUp">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header: device name + X -->
            <Grid Margin="2,2,2,2">
                <TextBlock x:Name="DeviceLabel"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="9" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="OnClosePopout" Width="16" Height="16"
                        Cursor="Hand" ToolTip="Close">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="✕" FontSize="11" FontWeight="Bold"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="IndianRed"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <ItemsControl x:Name="TilesItems" ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:TileData}">
                        <Border Width="{DynamicResource TileWidth}" Height="{DynamicResource TileHeight}"
                                Padding="{DynamicResource SkinTilePadding}"
                                Margin="{DynamicResource SkinTileMargin}"
                                CornerRadius="{DynamicResource SkinTileCornerRadius}"
                                BorderThickness="{DynamicResource SkinTileBorderThickness}"
                                BorderBrush="{DynamicResource SkinTileBorderBrush}"
                                Opacity="{DynamicResource SkinTileOpacity}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SkinTileBackground}"/>
                                    <Setter Property="Effect" Value="{DynamicResource SkinTileEffect}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FlashActive}" Value="True">
                                            <Setter Property="Background" Value="{Binding FlashBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Header}" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Row="1" Text="{Binding SubHeader}" Style="{StaticResource SubHeaderText}"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding IsStacked, Converter={StaticResource InvBoolVis}}">
                                    <TextBlock local:Fmt.Text="{Binding PrimaryValue}" local:Fmt.AccentOverride="{Binding AccentOverride}" Style="{StaticResource PrimaryText}"/>
                                    <TextBlock Text="{Binding PrimaryUnit}" Style="{StaticResource UnitText}"/>
                                </StackPanel>
                                <Grid Grid.Row="2" VerticalAlignment="Center" Margin="2,0,0,0"
                                      Visibility="{Binding IsStacked, Converter={StaticResource BoolVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Line1Label}" Style="{StaticResource PrimaryText}" Foreground="{DynamicResource MutedTextBrush}" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" local:Fmt.Text="{Binding Line1Value}" local:Fmt.AccentOverride="{Binding AccentOverride}" Style="{StaticResource PrimaryText}" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Line2Label}" Style="{StaticResource PrimaryText}" Foreground="{DynamicResource MutedTextBrush}" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" local:Fmt.Text="{Binding Line2Value}" local:Fmt.AccentOverride="{Binding AccentOverride}" Style="{StaticResource PrimaryText}" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Grid.Row="3" local:Fmt.Text="{Binding SecondaryValue}" local:Fmt.AccentOverride="{Binding AccentOverride}" Style="{StaticResource SecondaryValueText}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>

<UserControl x:Class="Fluid.App.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <Style x:Key="PresetSwatch" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource TileBrush}" CornerRadius="8" Padding="12">
        <StackPanel>

            <!-- SV Square -->
            <Grid Width="196" Height="150" Margin="0,0,0,8" Cursor="Cross">
                <!-- Base hue fill -->
                <Rectangle x:Name="SvBase" RadiusX="4" RadiusY="4"/>
                <!-- White overlay: NOT hit-testable -->
                <Rectangle RadiusX="4" RadiusY="4" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White"       Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Black overlay: NOT hit-testable -->
                <Rectangle RadiusX="4" RadiusY="4" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="Black"       Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Canvas MUST have Background set or mouse events don't fire -->
                <Canvas x:Name="SvCanvas" Background="Transparent" ClipToBounds="True"
                        MouseDown="SvCanvas_MouseDown"
                        MouseMove="SvCanvas_MouseMove"
                        MouseUp="SvCanvas_MouseUp">
                    <Ellipse x:Name="SvCursor" Width="12" Height="12"
                             Stroke="White" StrokeThickness="2" Fill="Transparent"
                             Canvas.Left="0" Canvas.Top="0" IsHitTestVisible="False"/>
                </Canvas>
            </Grid>

            <!-- Hue slider -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="HueSlider" Minimum="0" Maximum="360"
                        ValueChanged="HueSlider_ValueChanged"/>
                <Rectangle Grid.Column="1" Width="20" Height="14" Margin="6,0,0,0"
                           RadiusX="3" RadiusY="3" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF0000" Offset="0"/>
                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                            <GradientStop Color="#00FF00" Offset="0.333"/>
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                            <GradientStop Color="#0000FF" Offset="0.667"/>
                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                            <GradientStop Color="#FF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <!-- Alpha slider -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="AlphaSlider" Minimum="0" Maximum="255"
                        ValueChanged="AlphaSlider_ValueChanged"/>
                <TextBlock Grid.Column="1" Text="A" Margin="6,0,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="10" VerticalAlignment="Center"/>
            </Grid>

            <!-- Preset colors -->
            <TextBlock Text="Presets" Foreground="{DynamicResource MutedTextBrush}"
                       FontSize="10" Margin="0,4,0,4"/>
            <WrapPanel x:Name="PresetPanel" Margin="0,0,0,8">
                <Button Tag="#FF003FBD" Style="{StaticResource PresetSwatch}" ToolTip="Deep Blue"      Click="OnPreset"/>
                <Button Tag="#FF00C8FF" Style="{StaticResource PresetSwatch}" ToolTip="Sky Blue"       Click="OnPreset"/>
                <Button Tag="#FF00FFB4" Style="{StaticResource PresetSwatch}" ToolTip="Mint"           Click="OnPreset"/>
                <Button Tag="#FF00E676" Style="{StaticResource PresetSwatch}" ToolTip="Neon Green"     Click="OnPreset"/>
                <Button Tag="#FF8B00FF" Style="{StaticResource PresetSwatch}" ToolTip="Deep Violet"    Click="OnPreset"/>
                <Button Tag="#FFDD00FF" Style="{StaticResource PresetSwatch}" ToolTip="Magenta"        Click="OnPreset"/>
                <Button Tag="#FFFF0080" Style="{StaticResource PresetSwatch}" ToolTip="Hot Pink"       Click="OnPreset"/>
                <Button Tag="#FFFF6B00" Style="{StaticResource PresetSwatch}" ToolTip="Amber"          Click="OnPreset"/>
                <Button Tag="#FFFFE066" Style="{StaticResource PresetSwatch}" ToolTip="Gold"           Click="OnPreset"/>
                <Button Tag="#FFFF2020" Style="{StaticResource PresetSwatch}" ToolTip="Red"            Click="OnPreset"/>
                <Button Tag="#FFF0F4FF" Style="{StaticResource PresetSwatch}" ToolTip="Arctic White"   Click="OnPreset"/>
                <Button Tag="#FF607080" Style="{StaticResource PresetSwatch}" ToolTip="Steel"          Click="OnPreset"/>
            </WrapPanel>

            <!-- Preview + Hex -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="PreviewSwatch" CornerRadius="4"
                        Width="36" Height="28" HorizontalAlignment="Left"/>
                <TextBox x:Name="HexBox" Grid.Column="1" Margin="8,0,0,0"
                         Padding="4,3" FontFamily="Consolas" FontSize="11"
                         TextChanged="HexBox_TextChanged"
                         LostFocus="HexBox_LostFocus"/>
            </Grid>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Apply" Padding="10,4" Margin="0,0,6,0" Click="OnApply"/>
                <Button Content="Cancel" Padding="10,4" Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

<Window x:Class="Fluid.App.WarningsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:beh="clr-namespace:Fluid.App.Behaviors"
        xmlns:m="clr-namespace:Fluid.Shared.Protocol;assembly=Fluid.Shared"
        Title="TILE ALERTS"
        Width="460" SizeToContent="Height"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource BorderlessWindow}"
        KeyDown="OnWindowKeyDown">
    <Grid>
        <!-- v1.25.10: chrome overlay sits inside the 32px caption area
             defined by WindowChrome. The original content (below) keeps
             its existing layout and Margin (no structural change). The
             default Window template still hosts both, so UI Automation
             walks the tree normally. -->
        <Button Content="TILE ALERTS" Style="{StaticResource SplitBackButton}"
                FontSize="11" FontWeight="Bold"
                Foreground="{DynamicResource TextBrush}"
                Panel.ZIndex="100"
                beh:WindowClose.IsClose="True"/>
        <Button Style="{StaticResource BorderlessCloseButton}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,6,0"
                Panel.ZIndex="100"
                beh:WindowClose.IsClose="True"/>
        <DockPanel Margin="0,32,0,0">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="16,8,16,14">
            <Button Content="Save &amp; Close" Style="{StaticResource BottomBarPrimary}" Click="OnSave"/>
        </StackPanel>

        <StackPanel Margin="16">
            
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                       Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                       Text="When the temperature threshold is crossed, the tile background flashes. Gradient mode shifts the unit color from dark-blue (cool) to bright-red (hot) continuously. Thresholds are always in °C."/>

            <ItemsControl x:Name="WarnList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:TileWarning}">
                        <Border Background="{DynamicResource TileBrush}" CornerRadius="8"
                                Padding="12,10" Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Enabled toggle with tile name -->
                                <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                          Foreground="{DynamicResource TextBrush}"
                                          FontWeight="Bold" FontSize="13"
                                          Content="{Binding DisplayName}"
                                          Margin="0,0,0,8"/>

                                <!-- Config (dims when disabled) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Threshold -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Threshold" Width="90"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontWeight="SemiBold" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Width="70" Padding="4,3"
                                                 Text="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Text=" °C" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                                    </StackPanel>

                                    <!-- Flash -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Flash" Width="90"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontWeight="SemiBold" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox Content="Enable flash" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding FlashEnabled, Mode=TwoWay}"
                                                  Foreground="{DynamicResource TextBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBox Width="90" Padding="4,3"
                                                 Text="{Binding FlashColor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="Consolas" FontSize="10"/>
                                    </StackPanel>

                                    <!-- Gradient -->
                                    <CheckBox Content="Gradient mode — unit color shifts dark-blue → bright-red by temperature"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding GradientMode, Mode=TwoWay}"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </DockPanel>
    </Grid>
</Window>

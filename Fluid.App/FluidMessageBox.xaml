<Window x:Class="Fluid.App.FluidMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:beh="clr-namespace:Fluid.App.Behaviors"
        Title="fluidMonitor"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource BorderlessWindow}">
    <Grid>
        <TextBlock x:Name="TitleLabel" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="14,8,0,0" Panel.ZIndex="100"/>
        <Button Style="{StaticResource BorderlessCloseButton}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,6,0" Panel.ZIndex="100"
                beh:WindowClose.IsClose="True"/>
        <StackPanel Margin="22,48,22,18">
            <TextBlock x:Name="MessageLabel" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextBrush}" LineHeight="20"
                       Margin="0,0,0,20"/>
            <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>

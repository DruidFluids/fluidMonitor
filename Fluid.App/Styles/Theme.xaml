<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#E61E1E22"/>
    <SolidColorBrush x:Key="TileBrush"            Color="#FF2A2A30"/>
    <SolidColorBrush x:Key="SkinTileBackground"   Color="#FF2A2A30"/>
    <SolidColorBrush x:Key="AccentBrush"     Color="#FF00A8FF"/>
    <!-- v1.21: raw accent Color (not a brush) for effects that need a Color,
         e.g. the Glow traffic indicator's DropShadowEffect. Kept in sync with
         AccentBrush by ThemeApplier.Apply. -->
    <Color x:Key="AccentGlowColor">#FF00A8FF</Color>
    <SolidColorBrush x:Key="TextBrush"       Color="#FFE8E8EC"/>
    <SolidColorBrush x:Key="MutedTextBrush"  Color="#FF9A9AA8"/>

    <!-- Font sizes (set by ThemeApplier, defaults here for design-time) -->
    <sys:Double x:Key="PrimaryFontSize"   xmlns:sys="clr-namespace:System;assembly=mscorlib">18</sys:Double>
    <sys:Double x:Key="SecondaryFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>
    <sys:Double x:Key="UnitFontSize"      xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="IndicatorFontSize"      xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="SmallIndicatorFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <!-- v1.25.16: per-tile granular sizes (arrows, disk labels). Default to
         the same values as the generic indicator sizes; ThemeApplier
         overrides them at runtime once user offsets are loaded. -->
    <sys:Double x:Key="ArrowFontSize"          xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="DiskLabelFontSize"      xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <!-- v1.25.20: clock date line is bumped above SecondaryFontSize because
         it's a centerpiece display, not an auxiliary "MHz" / "load %" line. -->
    <sys:Double x:Key="ClockDateFontSize"      xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>

    <!-- Tile card — FlashActive DataTrigger swaps background -->

    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{DynamicResource MutedTextBrush}"/>
        <Setter Property="FontSize"      Value="{DynamicResource IndicatorFontSize}"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SubHeaderText" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{DynamicResource MutedTextBrush}"/>
        <Setter Property="FontSize"      Value="{DynamicResource SecondaryFontSize}"/>
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="Opacity"       Value="0.8"/>
        <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin"        Value="0,1,0,0"/>
        <Style.Triggers>
            <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PrimaryText" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontSize"      Value="{DynamicResource PrimaryFontSize}"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
    </Style>

    <Style x:Key="UnitText" TargetType="TextBlock">
        <Setter Property="Foreground"       Value="{DynamicResource AccentBrush}"/>
        <Setter Property="FontSize"         Value="{DynamicResource UnitFontSize}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin"           Value="2,0,0,2"/>
        <Style.Triggers>
            <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryValueText" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontSize"      Value="{DynamicResource SecondaryFontSize}"/>
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="Opacity"       Value="0.85"/>
        <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
    </Style>

    <!-- Device switcher buttons -->
    <Style x:Key="DeviceSwitchBtn" TargetType="Button">
        <Setter Property="Background"    Value="{DynamicResource TileBrush}"/>
        <Setter Property="Foreground"    Value="{DynamicResource MutedTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"       Value="8,3"/>
        <Setter Property="Margin"        Value="2,0"/>
        <Setter Property="FontSize"      Value="9"/>
        <Setter Property="FontWeight"    Value="SemiBold"/>
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="Cursor"        Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DeviceSwitchBtnActive" TargetType="Button" BasedOn="{StaticResource DeviceSwitchBtn}">
        <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
    </Style>

    <!-- Settings styles -->
    <!-- Toggle switch — pill-shaped animated CheckBox -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="32" Height="18" VerticalAlignment="Center">
                            <Border x:Name="Track" CornerRadius="9"
                                    Background="{DynamicResource MutedTextBrush}" Opacity="0.45"/>
                            <Ellipse x:Name="Thumb" Width="13" Height="13" Fill="{DynamicResource TextBrush}"
                                     HorizontalAlignment="Left" Margin="2.5,0,0,0"
                                     VerticalAlignment="Center">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbPos" X="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.2"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="Track" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbPos"
                                                         Storyboard.TargetProperty="X"
                                                         To="14" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbPos"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsCheckBox" TargetType="CheckBox" BasedOn="{StaticResource ToggleSwitch}">
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <Style x:Key="SettingsLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin"     Value="0,12,0,4"/>
    </Style>

    <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin"     Value="0,16,0,8"/>
    </Style>


    <Style x:Key="PosRadio" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>

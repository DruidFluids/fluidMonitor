<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Shape -->
    <CornerRadius x:Key="SkinTileCornerRadius">14,14,14,14</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">18,18,18,18</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,10</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">1.5</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">0</Thickness>
    <Thickness x:Key="SkinContentMargin">0</Thickness>

    <!-- Bright glass edge: Text color at 67% alpha (was hardcoded #AAFFFFFF) -->
    <sys:String x:Key="SkinTileBorderSource">Text</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">0.67</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Transparent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">0</sys:Double>

    <!-- Tile background: special glass-gradient kind (synthesized from Accent/Background/Tile by ThemeApplier) -->
    <sys:String x:Key="SkinTileBackgroundKind">Glass</sys:String>

    <!-- Glow shadow uses Accent for that colored-bloom effect -->
    <sys:String x:Key="SkinShadowSource">Accent</sys:String>
    <sys:Double x:Key="SkinShadowAlpha">0.85</sys:Double>
    <sys:Double x:Key="SkinShadowDepth">0</sys:Double>
    <sys:Double x:Key="SkinShadowBlur">28</sys:Double>

    <!-- Placeholders (overwritten by ThemeApplier) -->
    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="#AAFFFFFF"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="Transparent"/>
    <LinearGradientBrush x:Key="SkinTileBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#55AACCFF" Offset="0"/>
        <GradientStop Color="#331133AA" Offset="0.5"/>
        <GradientStop Color="#22001166" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sheen: white reflection (uses Text color for theme-correctness) -->
    <x:Double x:Key="SkinSheenOpacity">1.0</x:Double>
    <sys:String x:Key="SkinSheenSource">Text</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0.53</sys:Double>

    <!-- No header bar, no accent bar -->
    <x:Double x:Key="SkinHeaderBarHeight">0</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">0</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Transparent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">0</CornerRadius>
    <x:Double x:Key="SkinAccentBarWidth">0</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">0</x:Double>

    <!-- Typography -->
    <FontFamily x:Key="SkinFontFamily">Segoe UI</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">Light</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">1</x:Double>

    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

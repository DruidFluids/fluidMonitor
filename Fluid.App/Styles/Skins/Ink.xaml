<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Ink: type-forward. Header underline only, ultra-light decoration. -->
    <CornerRadius x:Key="SkinTileCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">2,2,2,2</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,4</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">0,2,0,0</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">0</Thickness>
    <Thickness x:Key="SkinContentMargin">0</Thickness>

    <!-- Top edge accent only — like a header underline above the tile -->
    <sys:String x:Key="SkinTileBorderSource">Text</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">0.8</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Transparent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">0</sys:Double>

    <sys:String x:Key="SkinShadowSource">None</sys:String>

    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="#CCE8E8EC"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="Transparent"/>
    <x:Null x:Key="SkinTileEffect"/>

    <x:Double x:Key="SkinSheenOpacity">0</x:Double>
    <sys:String x:Key="SkinSheenSource">Transparent</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0</sys:Double>

    <x:Double x:Key="SkinHeaderBarHeight">0</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">0</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Transparent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">0</CornerRadius>

    <x:Double x:Key="SkinAccentBarWidth">0</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">0</x:Double>

    <FontFamily x:Key="SkinFontFamily">Segoe UI</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">Light</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">1</x:Double>
    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

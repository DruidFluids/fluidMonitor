<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <CornerRadius x:Key="SkinTileCornerRadius">4,4,4,4</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">4,4,4,4</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,6</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">2</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">2</Thickness>
    <Thickness x:Key="SkinContentMargin">0</Thickness>

    <!-- Retro: borders use Accent color (signature look) -->
    <sys:String x:Key="SkinTileBorderSource">Accent</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">1.0</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Accent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">1.0</sys:Double>

    <sys:String x:Key="SkinShadowSource">None</sys:String>

    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="#FF00A8FF"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="#FF00A8FF"/>
    <x:Null x:Key="SkinTileEffect"/>

    <x:Double x:Key="SkinSheenOpacity">0</x:Double>
    <sys:String x:Key="SkinSheenSource">Transparent</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0</sys:Double>

    <!-- Header bar uses Accent at 80% alpha — the "title bar" look -->
    <x:Double x:Key="SkinHeaderBarHeight">20</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">1</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Accent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0.8</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">2,2,0,0</CornerRadius>

    <x:Double x:Key="SkinAccentBarWidth">0</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">0</x:Double>

    <FontFamily x:Key="SkinFontFamily">Consolas</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">Bold</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">1</x:Double>
    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

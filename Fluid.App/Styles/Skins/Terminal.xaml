<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Terminal: CRT/tmux pane aesthetic. Monospace, hairline accent borders, no chrome. -->
    <CornerRadius x:Key="SkinTileCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">0</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,1</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">1</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">1</Thickness>
    <Thickness x:Key="SkinContentMargin">0</Thickness>

    <sys:String x:Key="SkinTileBorderSource">Accent</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">0.6</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Accent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">0.6</sys:Double>

    <sys:String x:Key="SkinShadowSource">None</sys:String>

    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="#9900A8FF"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="#9900A8FF"/>
    <x:Null x:Key="SkinTileEffect"/>

    <x:Double x:Key="SkinSheenOpacity">0</x:Double>
    <sys:String x:Key="SkinSheenSource">Transparent</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0</sys:Double>

    <x:Double x:Key="SkinHeaderBarHeight">0</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">0</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Transparent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">0</CornerRadius>

    <x:Double x:Key="SkinAccentBarWidth">0</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">0</x:Double>

    <FontFamily x:Key="SkinFontFamily">Cascadia Mono, Consolas, Courier New</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">Normal</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">0.85</x:Double>
    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

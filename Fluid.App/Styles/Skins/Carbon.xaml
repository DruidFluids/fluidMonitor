<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Carbon: premium dark panels. Subtle gradient, hairline Muted border, no glow. -->
    <CornerRadius x:Key="SkinTileCornerRadius">6,6,6,6</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">8,8,8,8</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,4</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">1</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">0</Thickness>
    <Thickness x:Key="SkinContentMargin">0</Thickness>

    <sys:String x:Key="SkinTileBorderSource">Muted</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">0.5</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Transparent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">0</sys:Double>

    <!-- Soft inner-feeling shadow using Background (creates depth illusion) -->
    <sys:String x:Key="SkinShadowSource">Background</sys:String>
    <sys:Double x:Key="SkinShadowAlpha">0.7</sys:Double>
    <sys:Double x:Key="SkinShadowDepth">1</sys:Double>
    <sys:Double x:Key="SkinShadowBlur">6</sys:Double>

    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="#809A9AA8"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="Transparent"/>

    <!-- Faint Tile-color sheen for the brushed-metal feel -->
    <x:Double x:Key="SkinSheenOpacity">0.3</x:Double>
    <sys:String x:Key="SkinSheenSource">Tile</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0.4</sys:Double>

    <x:Double x:Key="SkinHeaderBarHeight">0</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">0</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Transparent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">0</CornerRadius>

    <x:Double x:Key="SkinAccentBarWidth">0</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">0</x:Double>

    <FontFamily x:Key="SkinFontFamily">Segoe UI</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">Medium</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">0.85</x:Double>
    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

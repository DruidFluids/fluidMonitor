<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Cyberpunk: angular and aggressive. Asymmetric left accent stripe, bold accent headers. -->
    <CornerRadius x:Key="SkinTileCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">0</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,3</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">0,1,0,1</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">0</Thickness>
    <Thickness x:Key="SkinContentMargin">10,0,0,0</Thickness>

    <!-- Top/bottom edges in Accent (defined by border thickness above) -->
    <sys:String x:Key="SkinTileBorderSource">Accent</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">0.9</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Transparent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">0</sys:Double>

    <!-- Tight accent glow -->
    <sys:String x:Key="SkinShadowSource">Accent</sys:String>
    <sys:Double x:Key="SkinShadowAlpha">0.5</sys:Double>
    <sys:Double x:Key="SkinShadowDepth">0</sys:Double>
    <sys:Double x:Key="SkinShadowBlur">8</sys:Double>

    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="#E600A8FF"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="Transparent"/>

    <x:Double x:Key="SkinSheenOpacity">0</x:Double>
    <sys:String x:Key="SkinSheenSource">Transparent</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0</sys:Double>

    <x:Double x:Key="SkinHeaderBarHeight">0</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">0</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Transparent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">0</CornerRadius>

    <!-- Asymmetric left stripe — defining cyberpunk feature -->
    <x:Double x:Key="SkinAccentBarWidth">5</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">1</x:Double>

    <FontFamily x:Key="SkinFontFamily">Segoe UI</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">Black</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">1</x:Double>
    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

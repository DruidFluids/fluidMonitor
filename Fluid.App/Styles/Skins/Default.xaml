<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Shape -->
    <CornerRadius x:Key="SkinTileCornerRadius">12,12,12,12</CornerRadius>
    <CornerRadius x:Key="WidgetCornerRadius">16,16,16,16</CornerRadius>
    <Thickness x:Key="SkinTilePadding">2,1</Thickness>
    <Thickness x:Key="SkinTileMargin">0,0,0,6</Thickness>
    <Thickness x:Key="SkinTileBorderThickness">0</Thickness>
    <Thickness x:Key="SkinWidgetBorderThickness">0</Thickness>
    <Thickness x:Key="SkinContentMargin">0</Thickness>

    <!-- Color slots (resolved by ThemeApplier.ApplySkinSlots from current theme colors) -->
    <sys:String x:Key="SkinTileBorderSource">Transparent</sys:String>
    <sys:Double x:Key="SkinTileBorderAlpha">0</sys:Double>
    <sys:String x:Key="SkinWidgetBorderSource">Transparent</sys:String>
    <sys:Double x:Key="SkinWidgetBorderAlpha">0</sys:Double>

    <!-- Subtle drop shadow using Background color (dark on light, dark on dark works) -->
    <sys:String x:Key="SkinShadowSource">Background</sys:String>
    <sys:Double x:Key="SkinShadowAlpha">0.25</sys:Double>
    <sys:Double x:Key="SkinShadowDepth">2</sys:Double>
    <sys:Double x:Key="SkinShadowBlur">10</sys:Double>

    <!-- Placeholder brushes/effect (overwritten by ThemeApplier on startup) -->
    <SolidColorBrush x:Key="SkinTileBorderBrush"   Color="Transparent"/>
    <SolidColorBrush x:Key="SkinWidgetBorderBrush" Color="Transparent"/>

    <!-- Overlay: sheen — off for default -->
    <x:Double x:Key="SkinSheenOpacity">0</x:Double>
    <sys:String x:Key="SkinSheenSource">Transparent</sys:String>
    <sys:Double x:Key="SkinSheenAlpha">0</sys:Double>

    <!-- Overlay: header bar — off for default -->
    <x:Double x:Key="SkinHeaderBarHeight">0</x:Double>
    <x:Double x:Key="SkinHeaderBarOpacity">0</x:Double>
    <sys:String x:Key="SkinHeaderBarSource">Transparent</sys:String>
    <sys:Double x:Key="SkinHeaderBarAlpha">0</sys:Double>
    <CornerRadius x:Key="SkinHeaderBarCornerRadius">0</CornerRadius>

    <!-- Overlay: accent bar -->
    <x:Double x:Key="SkinAccentBarWidth">0</x:Double>
    <x:Double x:Key="SkinAccentBarOpacity">0</x:Double>

    <!-- Typography -->
    <FontFamily x:Key="SkinFontFamily">Segoe UI</FontFamily>
    <FontWeight x:Key="SkinHeaderFontWeight">SemiBold</FontWeight>
    <x:Double x:Key="SkinHeaderOpacity">1</x:Double>
    <x:Double x:Key="SkinTileOpacity">1.0</x:Double>
    <x:Double x:Key="SkinWidgetOpacity">1.0</x:Double>
</ResourceDictionary>

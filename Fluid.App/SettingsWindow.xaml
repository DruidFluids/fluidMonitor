<Window x:Class="Fluid.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Fluid.App"
        xmlns:beh="clr-namespace:Fluid.App.Behaviors"
        xmlns:proto="clr-namespace:Fluid.Shared.Protocol;assembly=Fluid.Shared"
        Title="fluidMonitor — Settings"
        SizeToContent="Height"
        Width="720"
        MaxHeight="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource BorderlessWindow}">

    <Window.Resources>

        <!-- ComboBox full dark template -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="6,4"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                      Stroke="{DynamicResource MutedTextBrush}"
                                                      StrokeThickness="1.5" Fill="Transparent"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDown"
                                        Background="{DynamicResource TileBrush}"
                                        BorderBrush="{DynamicResource MutedTextBrush}"
                                        BorderThickness="1" CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill toggle button -->
        <Style x:Key="PillBtn" TargetType="ToggleButton">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource MutedTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Mode button (sun/moon) -->
        <Style x:Key="ModeBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Underline text input -->
        <Style x:Key="LineInput" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="2,2,2,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HexInput" TargetType="TextBox" BasedOn="{StaticResource LineInput}">
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Thin slider -->
        <Style x:Key="Slim" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="2" Background="{DynamicResource AccentBrush}" CornerRadius="1"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12"
                                                         Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource BackgroundBrush}"
                                                         StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="2" Background="{DynamicResource MutedTextBrush}" Opacity="0.25" CornerRadius="1"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Swatch - full fill with label inside -->
        <Style x:Key="Sw" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small button -->
        <Style x:Key="Sm" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- v1.25.36: modern theme-aware bottom-bar buttons replacing the
             Windows-gray Sm style on the bottom row. Flat: tile background,
             1px muted border, rounded corners. Hover lights border + text to
             accent; press fills with accent and inverts text to the
             background color. All DynamicResource so every theme matches. -->
        <Style x:Key="BottomBar" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v1.25.36: destructive variant - red border + red text at rest. -->
        <Style x:Key="BottomBarDanger" TargetType="Button" BasedOn="{StaticResource BottomBar}">
            <Setter Property="BorderBrush" Value="IndianRed"/>
            <Setter Property="Foreground" Value="IndianRed"/>
        </Style>

        <!-- v1.25.36: primary call-to-action - filled accent, semibold. -->
        <Style x:Key="BottomBarPrimary" TargetType="Button" BasedOn="{StaticResource BottomBar}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v1.25.37: compact inline button matching the modern BottomBar look
             but sized for inline use (smaller padding, same rounded+bordered
             treatment). Replaces the old unstyled Sm buttons throughout. -->
        <Style x:Key="InlineBtn" TargetType="Button" BasedOn="{StaticResource BottomBar}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- v1.25.40: compact cycler button matching the combobox/dropdown look.
             TileBrush fill, faint muted border, rounded corners. Hover accents. -->
        <Style x:Key="CyclerBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section header -->
        <Style x:Key="SH" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Toggle in settings (with label, horizontal) -->
        <Style x:Key="SW" TargetType="CheckBox" BasedOn="{StaticResource ToggleSwitch}">
            <Setter Property="Margin" Value="0,0,16,6"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- v1.25.10: chrome overlay sits inside the 32px caption area defined
             by WindowChrome. Original DockPanel content keeps its layout. -->
        <!-- v1.25.11: title text in the caption area, matches modern app chrome. -->
        <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="14,8,0,0" Panel.ZIndex="100"/>
        <Button Style="{StaticResource BorderlessCloseButton}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,6,0"
                Panel.ZIndex="100"
                beh:WindowClose.IsClose="True"/>

    <DockPanel Margin="0,32,0,0">

        <!-- Device selector bar -->
        <Border x:Name="DeviceSelectorBar" DockPanel.Dock="Top"
                Padding="20,8" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource MutedTextBrush}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ItemsControl x:Name="SettingsDeviceSelector">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <!-- ? tooltip -->
                <Border Width="14" Height="14" CornerRadius="7" Margin="8,0,0,0"
                        Background="{DynamicResource MutedTextBrush}" Opacity="0.5"
                        VerticalAlignment="Center" Cursor="Help"
                        ToolTipService.InitialShowDelay="0">
                    <Border.ToolTip>
                        <ToolTip MaxWidth="220">
                            <TextBlock FontSize="11" TextWrapping="Wrap" Padding="2"
                                       Text="Switch between devices to configure their tiles, labels, and layout independently."/>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Text="?" FontSize="9" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom" Padding="20,10"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource MutedTextBrush}" Opacity="0.8">
            <!-- v1.25.18: left group of action buttons + Save and Close pinned
                 to the right corner. Utilities added at the far left so it's
                 accessible directly from Settings instead of only via tray. -->
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right"  Content="Save and Close"    Style="{StaticResource BottomBarPrimary}" Click="OnClose"/>
                <!-- v1.0.4: split button leftmost, reset to its right -->
                <Border DockPanel.Dock="Left" CornerRadius="7" Margin="0,0,6,0"
                        BorderBrush="{DynamicResource MutedTextBrush}" BorderThickness="0.5"
                        SnapsToDevicePixels="True">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="?" Width="34" Height="30" Padding="0"
                                FontSize="14" FontWeight="Bold" Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderThickness="0" Click="OnOpenHelp"
                                ToolTip="Help — feature guide">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="7,0,0,7" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Width="0.5" Background="{DynamicResource MutedTextBrush}" Opacity="0.4"/>
                        <Button Content="⚙" Width="34" Height="30" Padding="0"
                                FontSize="13" Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource MutedTextBrush}"
                                BorderThickness="0" Click="OnOpenTools"
                                ToolTip="Tools — Alerts, Game Mode, Utilities">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="0,7,7,0" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
                <Button DockPanel.Dock="Left" Content="Reset to Defaults" Style="{StaticResource BottomBarDanger}" Margin="0,0,6,0" Click="OnResetAll"/>
            </DockPanel>
        </Border>

        <!-- v1.23.1: two-column content wrapped in a ScrollViewer. v1.25.4:
             MaxHeight is set in code-behind to the screen work area (the XAML
             value below is only the pre-Loaded fallback); once the left column
             outgrew that (v1.20.3 Disk section onward), everything below the
             fold (including the ENTIRE Disk picker) was silently clipped
             with no way to reach it. Auto scrollbar appears only when needed. -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,2,0" Focusable="False">
        <Grid Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT ══ -->
            <StackPanel Grid.Column="0">

                <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Tiles" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Choose which sensors appear on the widget." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                    <!-- Tile toggles in aligned grid -->
                <!-- v1.18: tile checkboxes are repositioned at runtime based on
                     AppSettings.TileOrder. The grid stays 3 cols x 2 rows; each
                     CheckBox is drag-reorderable. PositionTileChecks() in
                     SettingsWindow.xaml.cs assigns Grid.Row/Column. -->
                <Grid x:Name="TileTogglesGrid" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="CpuCheck"      Content="CPU"      Style="{StaticResource SW}" Checked="OnTileToggle" Unchecked="OnTileToggle"/>
                    <CheckBox x:Name="GpuCheck"      Content="GPU"      Style="{StaticResource SW}" Checked="OnTileToggle" Unchecked="OnTileToggle"/>
                    <CheckBox x:Name="RamCheck"      Content="RAM"      Style="{StaticResource SW}" Checked="OnTileToggle" Unchecked="OnTileToggle"/>
                    <CheckBox x:Name="NetworkCheck"  Content="Network"  Style="{StaticResource SW}" Checked="OnTileToggle" Unchecked="OnTileToggle"/>
                    <CheckBox x:Name="StorageCheck"  Content="Storage"  Style="{StaticResource SW}" Checked="OnTileToggle" Unchecked="OnTileToggle"/>
                    <CheckBox x:Name="DateTimeCheck" Content="Clock"    Style="{StaticResource SW}" Checked="OnTileToggle" Unchecked="OnTileToggle"/>
                </Grid>

                <!-- v1.25.37: CPU temp info + F/C rocker. Only visible when
                     the Sensors section has been dismissed. Clicking (i) opens
                     the sensor setup dialog; the rocker toggles temp units. -->
                <StackPanel x:Name="CpuTempSetupRow" Orientation="Horizontal" Margin="0,2,0,4"
                            Visibility="Collapsed">
                    <Border Width="16" Height="16" CornerRadius="8"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.5"
                            Cursor="Hand" ToolTip="Set up CPU temperature sensor"
                            MouseLeftButtonUp="OnCpuTempInfoClick">
                        <TextBlock Text="i" FontSize="9" FontStyle="Italic" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text=" CPU temperature" FontSize="11" Margin="4,0,0,0"
                               Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CpuTempStatus" FontSize="11" Margin="6,0,0,0"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <Border CornerRadius="5" BorderBrush="{DynamicResource MutedTextBrush}"
                            BorderThickness="1" Padding="0" Margin="8,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="CelsiusToggle" Content="°C"
                                          FontSize="11" Padding="8,3" Cursor="Hand"
                                          Click="OnTempUnitToggle"
                                          Background="Transparent"
                                          Foreground="{DynamicResource TextBrush}"
                                          BorderThickness="0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="brd" CornerRadius="4,0,0,4"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="brd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <ToggleButton x:Name="FahrenheitToggle" Content="°F"
                                          FontSize="11" Padding="8,3" Cursor="Hand"
                                          Click="OnTempUnitToggle"
                                          Background="Transparent"
                                          Foreground="{DynamicResource TextBrush}"
                                          BorderThickness="0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="brd" CornerRadius="0,4,4,0"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="brd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <!-- v1.19: FahrenheitCheck moved to the Behavior section so all 4 behavior toggles cluster together. -->

                <!-- Tile Labels -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Tile Labels" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Override the auto-detected hardware name shown on each tile." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- CPU label row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU" Style="{StaticResource FL}" Grid.Column="0"/>
                    <TextBox x:Name="CpuCustomNameBox" Grid.Column="1"
                             Style="{StaticResource LineInput}" IsEnabled="False"
                             TextChanged="OnCpuNameChanged"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                        <ToggleButton x:Name="CpuAutoBtn"   Content="Auto"   Style="{StaticResource PillBtn}"
                                      IsChecked="True" Margin="0,0,4,0" Click="OnCpuPillToggle"/>
                        <ToggleButton x:Name="CpuCustomBtn" Content="Custom" Style="{StaticResource PillBtn}"
                                      Click="OnCpuPillToggle"/>
                    </StackPanel>
                </Grid>

                <!-- GPU label row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="GPU" Style="{StaticResource FL}" Grid.Column="0"/>
                    <TextBox x:Name="GpuCustomNameBox" Grid.Column="1"
                             Style="{StaticResource LineInput}" IsEnabled="False"
                             TextChanged="OnGpuNameChanged"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                        <ToggleButton x:Name="GpuAutoBtn"   Content="Auto"   Style="{StaticResource PillBtn}"
                                      IsChecked="True" Margin="0,0,4,0" Click="OnGpuPillToggle"/>
                        <ToggleButton x:Name="GpuCustomBtn" Content="Custom" Style="{StaticResource PillBtn}"
                                      Click="OnGpuPillToggle"/>
                    </StackPanel>
                </Grid>

                <!-- Layout -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Layout" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Stack tiles vertically (tall) or horizontally (wide)." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <!-- v1.20.3: radio buttons replaced with paired toggle buttons.
                     The two buttons mutually exclude via OnLayoutToggle. -->
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="HorizToggle" Content="Horizontal"
                                  FontSize="11" Padding="14,4" Margin="0,0,4,0"
                                  Cursor="Hand" Click="OnLayoutToggle"
                                  Background="{DynamicResource TileBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderThickness="0">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="brd" CornerRadius="4"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <ToggleButton x:Name="VertToggle" Content="Vertical"
                                  FontSize="11" Padding="14,4"
                                  Cursor="Hand" Click="OnLayoutToggle"
                                  Background="{DynamicResource TileBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderThickness="0">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="brd" CornerRadius="4"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="brd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>

                <!-- Behavior -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Behavior" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Control how the widget behaves on your desktop." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <WrapPanel>
                    <CheckBox x:Name="TopmostCheck"      Content="Always on top" Style="{StaticResource SW}" Checked="OnTopmostToggle"      Unchecked="OnTopmostToggle"/>
                    <CheckBox x:Name="ClickThroughCheck" Content="Click-through" Style="{StaticResource SW}" Checked="OnClickThroughToggle" Unchecked="OnClickThroughToggle"/>
                    <CheckBox x:Name="SnapCheck"         Content="Snap to edges" Style="{StaticResource SW}" Checked="OnSnapToggle"         Unchecked="OnSnapToggle"/>
                    <CheckBox x:Name="SnapWindowsCheck"  Content="Snap to windows" Style="{StaticResource SW}" Checked="OnSnapWindowsToggle" Unchecked="OnSnapWindowsToggle"
                              ToolTip="When snapping is on, the widget also docks to the outer edges of other windows."/>
                    <!-- v1.23: per-user HKCU Run key, no elevation required (hence no UAC shield). -->
                    <CheckBox x:Name="StartupCheck"      Content="Run at Windows startup" Style="{StaticResource SW}" Checked="OnStartupToggle" Unchecked="OnStartupToggle"
                              ToolTip="Launch the widget when you sign in to Windows. Uses your user account only — no admin rights needed."/>
                </WrapPanel>

                <TextBlock Text="Click-through hotkey" Style="{StaticResource FL}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="HotkeyBox" Width="150" Style="{StaticResource LineInput}"
                             IsReadOnly="True" Cursor="Hand"
                             PreviewKeyDown="OnHotkeyCapture"
                             GotFocus="OnHotkeyBoxFocused" LostFocus="OnHotkeyBoxUnfocused"/>
                    <TextBlock x:Name="HotkeyPrompt" Text="  click to set" Style="{StaticResource FL}" Margin="0"/>
                    <Button Content="✕" Style="{StaticResource InlineBtn}" Padding="4,2" Margin="6,0,0,0"
                            FontSize="10" Click="OnClearHotkey"/>
                </StackPanel>

                <!-- v1.23.2: sliders packed two-up to keep the whole left column
                     above the fold (no settings scroll on a default window). -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Opacity" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                            <Slider x:Name="OpacitySlider" Style="{StaticResource Slim}"
                                    Minimum="0.3" Maximum="1.0" TickFrequency="0.05"
                                    VerticalAlignment="Center" ValueChanged="OnOpacityChanged"/>
                            <TextBlock x:Name="OpacityLabel" Grid.Column="1" Style="{StaticResource FL}"
                                       HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Update interval" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="IntervalSlider" Style="{StaticResource Slim}"
                                    Minimum="250" Maximum="5000" TickFrequency="250" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" ValueChanged="OnIntervalChanged"/>
                            <TextBlock x:Name="IntervalLabel" Grid.Column="1" Style="{StaticResource FL}"
                                       HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="UI scale" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                            <Slider x:Name="ScaleSlider" Style="{StaticResource Slim}" Minimum="0.75" Maximum="1.5" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnScaleChanged"/>
                            <TextBlock x:Name="ScaleLabel" Grid.Column="1" Style="{StaticResource FL}" HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tile width" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                            <Slider x:Name="WidthSlider" Style="{StaticResource Slim}" Minimum="110" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnWidthChanged"/>
                            <TextBlock x:Name="WidthLabel" Grid.Column="1" Style="{StaticResource FL}" HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Tile height" Style="{StaticResource FL}"/>
                <Grid Height="18" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                    <Slider x:Name="HeightSlider" Style="{StaticResource Slim}" Minimum="80" Maximum="150" TickFrequency="2" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnHeightChanged"/>
                    <TextBlock x:Name="HeightLabel" Grid.Column="1" Style="{StaticResource FL}" HorizontalAlignment="Right" Margin="0"/>
                </Grid>

                <!-- Network -->
                <StackPanel x:Name="NetworkSection">
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                    <TextBlock Text="Network" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Choose which adapter to monitor. Defaults to all adapters combined." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                    <!-- v1.23.2: traffic indicator moved above the adapter per user
                         request, with a wider (not taller) button. -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Row 0: Traffic indicator + Spacing slider -->
                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Traffic indicator" Style="{StaticResource FL}"/>
                            <Button x:Name="TrafficIndicatorBtn" Click="OnTrafficIndicatorCycle"
                                    Style="{StaticResource InlineBtn}"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="Click to cycle: Off > Blink > Fade > Glow">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TrafficPreviewDown" Text="↓ " FontSize="13"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TrafficBtnLabel" Text="Off" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TrafficPreviewUp"   Text=" ↑" FontSize="13"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" VerticalAlignment="Bottom">
                            <TextBlock Text="Arrow spacing" Style="{StaticResource FL}"/>
                            <Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                <Slider x:Name="NetArrowSpacingSlider" Style="{StaticResource Slim}"
                                        Minimum="8" Maximum="40" SmallChange="1" LargeChange="4"
                                        VerticalAlignment="Center"
                                        ValueChanged="OnNetworkArrowSpacingChanged"/>
                                <TextBlock x:Name="NetArrowSpacingLabel" Grid.Column="1"
                                           Style="{StaticResource FL}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"/>
                            </Grid>
                        </StackPanel>
                        <!-- Row 2: Monitor adapter + Size slider -->
                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Monitor adapter" Style="{StaticResource FL}"/>
                            <ComboBox x:Name="NetworkAdapterCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="OnNetworkAdapterChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding}" FontSize="11"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="2" VerticalAlignment="Bottom">
                            <TextBlock Text="Arrow size" Style="{StaticResource FL}"/>
                            <Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                <Slider x:Name="ArrowFontSizeSlider" Style="{StaticResource Slim}"
                                        Minimum="-5" Maximum="10" SmallChange="1" LargeChange="2"
                                        VerticalAlignment="Center"
                                        ValueChanged="OnArrowFontSizeChanged"/>
                                <TextBlock x:Name="ArrowFontSizeLabel" Grid.Column="1"
                                           Style="{StaticResource FL}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- v1.20.3: Disk section -->
                <StackPanel x:Name="DiskSection">
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                        <TextBlock Text="Disk" Style="{StaticResource SH}" Margin="0"/>
                        <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                                Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                                VerticalAlignment="Center" Cursor="Help"
                                ToolTipService.InitialShowDelay="0">
                            <Border.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="Pick which physical disk the Disk tile should track. Defaults to the disk holding your system drive; its model shows under the tile header. Changes apply live — no restart needed." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Tile label" Style="{StaticResource FL}"/>
                            <Button x:Name="DiskLabelStyleBtn" Click="OnDiskLabelStyleCycle"
                                    Style="{StaticResource InlineBtn}"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="Click to cycle: Drive letter, Model, Both"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" VerticalAlignment="Bottom">
                            <TextBlock Text="R: / W: spacing" Style="{StaticResource FL}"/>
                            <Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                <Slider x:Name="DiskLabelSpacingSlider" Style="{StaticResource Slim}"
                                        Minimum="8" Maximum="40" SmallChange="1" LargeChange="4"
                                        VerticalAlignment="Center"
                                        ValueChanged="OnDiskLabelSpacingChanged"/>
                                <TextBlock x:Name="DiskLabelSpacingLabel" Grid.Column="1"
                                           Style="{StaticResource FL}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Monitor disk" Style="{StaticResource FL}"/>
                            <ComboBox x:Name="DiskCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="OnDiskChanged"
                                      ToolTip="{Binding SelectedItem.Display, RelativeSource={RelativeSource Self}}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Display}" FontSize="11"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="2" VerticalAlignment="Bottom">
                            <TextBlock Text="R: / W: size" Style="{StaticResource FL}"/>
                            <Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                <Slider x:Name="DiskLabelFontSizeSlider" Style="{StaticResource Slim}"
                                        Minimum="-5" Maximum="10" SmallChange="1" LargeChange="2"
                                        VerticalAlignment="Center"
                                        ValueChanged="OnDiskLabelFontSizeChanged"/>
                                <TextBlock x:Name="DiskLabelFontSizeLabel" Grid.Column="1"
                                           Style="{StaticResource FL}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"/>
                            </Grid>
                        </StackPanel>                    </Grid>
                </StackPanel>

            </StackPanel>

            <!-- ══ RIGHT ══ -->
            <StackPanel Grid.Column="2">

                <!-- Appearance header -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                    <TextBlock Text="Appearance" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Customize colors. Click any swatch in the strip to open the color picker." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Mode + cycler + presets — centered.
                     v1.13 layout: Skin row sits directly above the Theme row with
                     '<' '>' arrows vertically aligned (v1.25.37: alignment kept
                     via an 84px spacer in the Colors row; moon/sun moved to the
                     Appearance header). -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">

                    <!-- v1.24: Saved Themes moved to the TOP of Appearance per user request.
                         v1.14: trailing Save button removed (empty slot click
                         opens save dialog directly - see RebuildUserPresetSlots).
                         v1.15: export/import (share code) buttons to the right. -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="Saved Themes" Style="{StaticResource FL}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel x:Name="UserPresetSlots" Orientation="Horizontal"/>
                        <!-- divider -->
                        <Border Width="1" Background="{DynamicResource MutedTextBrush}" Opacity="0.3" Margin="6,4,6,4"/>
                        <Button x:Name="ImportShareCodeBtn" Content="↙" Click="OnImportShareCode"
                                Width="24" Height="24" Padding="0" FontSize="14"
                                Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                Margin="0,0,3,0"
                                ToolTipService.InitialShowDelay="300">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="240">
                                        <TextBlock Text="Import appearance" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock Text="Paste a share code to apply someone else's appearance. Your current state is undoable via the back arrow."
                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.85"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <Button x:Name="ExportShareCodeBtn" Content="↗" Click="OnExportShareCode"
                                Width="24" Height="24" Padding="0" FontSize="14"
                                Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                ToolTipService.InitialShowDelay="300">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="240">
                                        <TextBlock Text="Export appearance" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock Text="Copies a share code to your clipboard that captures the current theme, skin, fonts, and sizes. Paste it anywhere to share your setup."
                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.85"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>

                    <!-- v1.20: NEW Preset Themes cycler row. Themes are colors+skin
                         combos (atomic apply). Independent undo and dice for the
                         theme axis. Folder button loads .fluidtheme JSON files. -->
                    <TextBlock Text="Preset Themes" FontSize="9" Opacity="0.6"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Button x:Name="ThemeDownloadBtn" Content="↓" Click="OnOpenThemeStore"
                                Width="34" Height="34" Padding="0" FontSize="15"
                                Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="#FF6AB0E8"
                                BorderThickness="0"
                                Margin="0,0,3,0"
                                ToolTip="Download theme packs from GitHub"/>
                        <Button x:Name="ThemeDiceBtn" Content="🎲" Click="OnRandomizeThemePreset"
                                Width="34" Height="34" Padding="0" FontSize="18"
                                Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                Margin="0,0,3,0"
                                ToolTip="Randomize theme (colors + skin together)"/>
                        <Border Width="13" Background="Transparent"/>
                        <Button x:Name="ThemePresetPrevBtn" Style="{StaticResource CyclerBtn}" Content="‹" Click="OnThemePresetPrev"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="15"/>
                        <!-- v1.24: cycler pills are now Buttons; clicking the field opens
                             the same browse popup the removed "⋮" button used to. -->
                        <Button x:Name="ThemePresetCyclerBtn" Height="24" Width="150" Cursor="Hand"
                                Click="OnThemePresetBrowse" Margin="3,0" Padding="8,0"
                                Background="{DynamicResource TileBrush}" BorderThickness="0"
                                ToolTip="Click to browse all themes">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate></Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ThemePresetAccentDot" Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ThemePresetNameLabel" FontSize="11"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ThemePresetNextBtn" Style="{StaticResource CyclerBtn}" Content="›" Click="OnThemePresetNext"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="15" Margin="0,0,3,0"/>
                        <Button x:Name="ThemePresetFolderBtn" Style="{StaticResource CyclerBtn}" Content="📁" Click="OnThemePresetFromFolder"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="12"
                                Margin="3,0,0,0" ToolTip="Load .fluidtheme from disk"/>
                    </StackPanel>

                    <!-- v1.24: Skins + Colors share one bordered group: together
                         they make up a theme, and the visual join says so. -->
                    <Border BorderBrush="{DynamicResource MutedTextBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="8,5,8,6" Margin="0,0,0,6">
                    <StackPanel>
                    <TextBlock Text="Skins" FontSize="9" Opacity="0.6"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>

                    <!-- Row 0: undo + dice + spacer + skin cycler + browse.
                         v1.16: undo uses Visibility="Hidden" (occupies space)
                         instead of Collapsed, so the dice never moves when undo
                         appears/disappears. The 2x2 grid (undo/dice over moon/sun)
                         stays perfectly aligned at all times. -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Button x:Name="UndoBtn" Content="↶" Click="OnUndoAppearance"
                                Width="34" Height="34" Padding="0" FontSize="16"
                                Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                Visibility="Hidden"
                                Margin="0,0,3,0" ToolTipService.InitialShowDelay="300">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="240">
                                        <TextBlock Text="Undo last change" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock Text="Reverts the last appearance change (dice roll, theme/skin pick, font change, or preset load). Up to 5 steps back."
                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.85"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <!-- v1.25.37: dual-icon dice (🎲+🎨) signals this rolls
                             skin AND colors. Left-click = both; right-click = skin only. -->
                        <Button x:Name="RandomizeBtn" Click="OnRandomizeAppearance"
                                MouseRightButtonUp="OnRandomizeSkinOnly"
                                Width="34" Height="34" Padding="0" FontSize="16"
                                Cursor="Hand"
                                Background="{DynamicResource TileBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                Margin="0,0,3,0" ToolTipService.InitialShowDelay="300"
                                Content="🎲">
                            <Button.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="260">
                                        <TextBlock Text="Randomize skin + colors" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock Text="Left-click: rolls a random skin AND color palette (a mashup). Right-click: rolls skin only, keeps current colors. Fonts roll too if 'Randomize fonts' is enabled."
                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.85"/>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <!-- Spacer to align Skin '<' with Theme '<' below. See v1.14 math. -->
                        <Border Width="10" Background="Transparent"/>
                        <Button x:Name="SkinPrevBtn" Style="{StaticResource CyclerBtn}" Content="‹" Click="OnSkinPrev"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="15"/>
                        <!-- v1.16: Width is FIXED (not MinWidth) so cycler doesn't jitter
                             when label text length changes during randomize. -->
                        <Button x:Name="SkinCyclerBtn" Height="24" Width="150" Cursor="Hand"
                                Click="OnSkinBrowse" Margin="3,0" Padding="8,0"
                                Background="{DynamicResource TileBrush}" BorderThickness="0"
                                ToolTip="Click to browse all skins">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate></Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="SkinAccentBar" Width="3" Height="13" CornerRadius="1.5"
                                        Margin="0,0,6,0" VerticalAlignment="Center"
                                        Background="{DynamicResource AccentBrush}"/>
                                <TextBlock x:Name="SkinNameLabel" FontSize="11"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SkinNextBtn" Style="{StaticResource CyclerBtn}" Content="›" Click="OnSkinNext"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="15" Margin="0,0,3,0"/>
                        <Button x:Name="SkinFolderBtn" Style="{StaticResource CyclerBtn}" Content="📁" Click="OnSkinFromFolder"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="12"
                                Margin="3,0,0,0" ToolTip="Load skin from folder"/>
                    </StackPanel>

                    <!-- v1.19: matching subtle "Colors" label above the theme row. -->
                    <TextBlock Text="Colors" FontSize="9" Opacity="0.6"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <ToggleButton x:Name="DarkModeBtn"  Content="🌙" Style="{StaticResource ModeBtn}"
                                      ToolTip="Dark mode"  Click="OnModeToggle" Margin="0,0,3,0"/>
                        <ToggleButton x:Name="LightModeBtn" Content="☀" Style="{StaticResource ModeBtn}"
                                      ToolTip="Light mode" Click="OnModeToggle" Margin="0,0,6,0"/>
                        <Border Width="1" Background="{DynamicResource MutedTextBrush}" Opacity="0.3" Margin="0,4,6,4"/>
                        <Button x:Name="ThemePrevBtn" Style="{StaticResource CyclerBtn}" Content="‹" Click="OnThemePrev"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="15"/>
                        <!-- v1.16: fixed Width matches Skin cycler to prevent jitter. -->
                        <Button x:Name="ThemeCyclerBtn" Height="24" Width="150" Cursor="Hand"
                                Click="OnThemeBrowse" Margin="3,0" Padding="8,0"
                                Background="{DynamicResource TileBrush}" BorderThickness="0"
                                ToolTip="Click to browse all color palettes">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate></Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ThemeAccentDot" Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ThemeNameLabel" FontSize="11"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ThemeNextBtn" Style="{StaticResource CyclerBtn}" Content="›" Click="OnThemeNext"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="15" Margin="0,0,3,0"/>
                        <!-- v1.16: + button to save current colors as a named color preset. -->
                        <Button x:Name="ThemeAddBtn" Style="{StaticResource CyclerBtn}" Content="+" Click="OnSaveColorPresetClicked"
                                Width="24" Height="24" Padding="0" Cursor="Hand" FontSize="14"
                                Margin="3,0,0,0" ToolTip="Save current colors as a named preset"/>
                    </StackPanel>
                    </StackPanel>
                    </Border>

                    <!-- v1.15: Export/Import code panel (visible when the user clicks Export or Import).
                         For Export: shows the generated code with Copy + Close buttons.
                         For Import: shows an editable textbox + Apply + Cancel. -->
                    <Border x:Name="ShareCodePanel" Visibility="Collapsed"
                            Margin="0,8,0,0" Padding="10"
                            Background="{DynamicResource TileBrush}" CornerRadius="6">
                        <StackPanel>
                            <TextBlock x:Name="ShareCodeLabel" Text="Share code" Style="{StaticResource FL}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ShareCodeBox" FontSize="10" TextWrapping="Wrap" MaxLines="3"
                                     Style="{StaticResource HexInput}" AcceptsReturn="False"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button x:Name="ShareCodeCopyBtn"   Content="Copy"   Style="{StaticResource InlineBtn}" Margin="0,0,6,0" Click="OnShareCodeCopy"/>
                                <Button x:Name="ShareCodeApplyBtn"  Content="Apply"  Style="{StaticResource InlineBtn}" Margin="0,0,6,0" Click="OnShareCodeApply"/>
                                <Button x:Name="ShareCodeCloseBtn"  Content="Close"  Style="{StaticResource InlineBtn}" Click="OnShareCodeClose"/>
                                <TextBlock x:Name="ShareCodeStatus" Style="{StaticResource FL}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Browse popup (Skin) — v1.13: same format as Theme browse,
                     but renders skin entries with a slim accent bar (not a dot)
                     to convey the skin's character. -->
                <Popup x:Name="SkinBrowsePopup" StaysOpen="False" AllowsTransparency="True"
                       PlacementTarget="{Binding ElementName=SkinCyclerBtn}"
                       Placement="Bottom" VerticalOffset="2">
                    <Border Background="{DynamicResource TileBrush}"
                            BorderBrush="{DynamicResource MutedTextBrush}" BorderThickness="1"
                            MinWidth="220" MaxHeight="320" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="SkinBrowseList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- v1.17: each row contains a real mini-tile preview
                                             built in code-behind from the skin's actual resources.
                                             Hover = subtle highlight; click = pick that skin. -->
                                        <Border Padding="4,3" Cursor="Hand" Margin="0,1"
                                                Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="1"
                                                CornerRadius="4"
                                                MouseLeftButtonUp="OnSkinBrowseItemClick" Tag="{Binding Name}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ContentControl Content="{Binding PreviewElement}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>

                <!-- Browse popup (Theme) -->
                <Popup x:Name="ThemeBrowsePopup" StaysOpen="False" AllowsTransparency="True"
                       PlacementTarget="{Binding ElementName=ThemeCyclerBtn}"
                       Placement="Bottom" VerticalOffset="2">
                    <Border Background="{DynamicResource TileBrush}"
                            BorderBrush="{DynamicResource MutedTextBrush}" BorderThickness="1"
                            MinWidth="220" MaxHeight="380" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ThemeBrowseList">
                                <!-- v1.20.5: collapsible group headers (franchise grouping for theme entries)
                                     v1.25.37: grouping re-enabled (was flat since v1.25.6). Built-in and
                                     Custom Colors render FLAT (no expander) so the regular defaults read
                                     as a plain list; only game franchises get folder expanders. -->
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="GroupItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GroupItem">
                                                            <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                                                <Expander.Header>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text=" ("
                                                                                   FontSize="11" Opacity="0.6"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding ItemCount}"
                                                                                   FontSize="11" Opacity="0.6"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text=")"
                                                                                   FontSize="11" Opacity="0.6"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Expander.Header>
                                                                <ItemsPresenter/>
                                                            </Expander>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <!-- Flat rendering: no header, items inline. -->
                                                    <DataTrigger Binding="{Binding Name}" Value="Built-in">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="GroupItem">
                                                                    <ItemsPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="Custom Colors">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="GroupItem">
                                                                    <ItemsPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="18,4" Cursor="Hand" Background="Transparent"
                                                MouseLeftButtonUp="OnBrowseItemClick" Tag="{Binding Name}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="7" Height="7" Margin="0,0,7,0"
                                                         VerticalAlignment="Center" Fill="{Binding AccentBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="11"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="ⓘ" FontSize="11" Margin="6,0,0,0"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding InfoVisibility}"
                                                           ToolTip="{Binding InfoText}"/>
                                                <Button Grid.Column="3" Content="✕" Margin="6,0,0,0"
                                                        Width="18" Height="18" Padding="0" FontSize="10"
                                                        Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource MutedTextBrush}"
                                                        Click="OnDeleteCustomColor"
                                                        Tag="{Binding CustomColorBaseName}"
                                                        Visibility="{Binding DeleteVisibility}"
                                                        ToolTip="Delete this color"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>

                <!-- v1.20: Preset Themes browse popup with collapsible franchise groups -->
                <Popup x:Name="ThemePresetBrowsePopup" StaysOpen="False" AllowsTransparency="True"
                       PlacementTarget="{Binding ElementName=ThemePresetCyclerBtn}"
                       Placement="Bottom" VerticalOffset="2">
                    <Border Background="{DynamicResource TileBrush}"
                            BorderBrush="{DynamicResource MutedTextBrush}" BorderThickness="1"
                            MinWidth="220" MaxHeight="380" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                            <ItemsControl x:Name="ThemePresetBrowseList">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="GroupItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GroupItem">
                                                            <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                                                <Expander.Header>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text=" ("
                                                                                   FontSize="11" Opacity="0.6"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding ItemCount}"
                                                                                   FontSize="11" Opacity="0.6"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text=")"
                                                                                   FontSize="11" Opacity="0.6"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Expander.Header>
                                                                <ItemsPresenter/>
                                                            </Expander>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Background="Transparent" BorderThickness="0"
                                                HorizontalContentAlignment="Stretch" Cursor="Hand"
                                                Padding="18,4" Click="OnThemePresetBrowseItemClick">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" Margin="0,0,7,0"
                                                         VerticalAlignment="Center" Fill="{Binding AccentBrush}"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border x:Name="ThemePacksBanner" Background="#083A8FD4"
                                    BorderBrush="#203A8FD4" BorderThickness="1"
                                    CornerRadius="6" Padding="10,8" Margin="6,6,6,6"
                                    Cursor="Hand" MouseLeftButtonDown="OnBrowseBannerClick">
                                <StackPanel>
                                    <TextBlock Text="↓ More themes on GitHub" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="BrowseBannerSubtext"
                                               Text="22 game franchise packs"
                                               FontSize="9" Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Popup>

                <!-- v1.20: Import success notice popup (matte) -->
                <Popup x:Name="ImportNoticePopup" StaysOpen="False" AllowsTransparency="True"
                       Placement="Center" PopupAnimation="Fade">
                    <Border CornerRadius="8" Padding="18,14" MaxWidth="320"
                            Background="{DynamicResource TileBrush}"
                            BorderBrush="{DynamicResource MutedTextBrush}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Import applied"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="These settings won't be saved unless you save them to a preset slot (1-5)."
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,12"/>
                            <Button Content="Got it" Click="OnImportNoticeClose"
                                    HorizontalAlignment="Right" Padding="14,5"
                                    Background="{DynamicResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Clear confirmation popup -->
                <Popup x:Name="ClearConfirmPopup" StaysOpen="False" AllowsTransparency="True"
                       Placement="Bottom" VerticalOffset="4" PopupAnimation="Fade">
                    <Border CornerRadius="8" Padding="12,8" Background="{DynamicResource AccentBrush}">
                        <StackPanel>
                            <TextBlock x:Name="ClearConfirmLabel" Text="Clear this preset?"
                                       FontSize="11" FontWeight="SemiBold" Foreground="White"
                                       Margin="0,0,0,6" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="ClearConfirmYes" Content="Yes, clear" Click="OnClearConfirmYes"
                                        Foreground="White" FontSize="11" Padding="10,3" Margin="0,0,6,0"
                                        Cursor="Hand" BorderBrush="White" Background="Transparent"/>
                                <Button Content="Cancel" Click="OnClearConfirmCancel"
                                        Foreground="White" FontSize="11" Padding="10,3"
                                        Cursor="Hand" Opacity="0.7" BorderBrush="White" Background="Transparent"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Save name dialog -->
                <Border x:Name="SavePresetPanel" Visibility="Collapsed"
                        Background="{DynamicResource TileBrush}" CornerRadius="6"
                        Padding="10,8" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock x:Name="SavePresetLabel" Text="Name this preset" Style="{StaticResource FL}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="SavePresetNameBox" Width="160" Style="{StaticResource LineInput}"
                                     KeyDown="OnSavePresetKeyDown"/>
                            <Button Content="Save"   Style="{StaticResource InlineBtn}" Margin="8,0,4,0" Click="OnConfirmSavePreset"/>
                            <Button Content="Cancel" Style="{StaticResource InlineBtn}" Click="OnCancelSavePreset"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- v1.25.37: redesigned color swatch strip. Taller swatches with
                     name labels and hex values below each. Active swatch gets a
                     2px highlight border. All click functionality preserved. -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Button x:Name="SwBg" Height="36" Click="OnSwatchClick" Tag="BackgroundColor" Cursor="Hand" BorderThickness="2" BorderBrush="{DynamicResource MutedTextBrush}" Padding="0">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            </ControlTemplate></Button.Template>
                        </Button>
                        <TextBlock x:Name="SwBgLabel" Text="Background" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="SwBgHex" FontSize="9" HorizontalAlignment="Center" FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedTextBrush}" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Button x:Name="SwTile" Height="36" Click="OnSwatchClick" Tag="TileColor" Cursor="Hand" BorderThickness="2" BorderBrush="{DynamicResource MutedTextBrush}" Padding="0">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            </ControlTemplate></Button.Template>
                        </Button>
                        <TextBlock x:Name="SwTileLabel" Text="Tile" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="SwTileHex" FontSize="9" HorizontalAlignment="Center" FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedTextBrush}" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <Button x:Name="SwAccent" Height="36" Click="OnSwatchClick" Tag="AccentColor" Cursor="Hand" BorderThickness="2" BorderBrush="{DynamicResource MutedTextBrush}" Padding="0">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            </ControlTemplate></Button.Template>
                        </Button>
                        <TextBlock x:Name="SwAccentLabel" Text="Accent" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock x:Name="SwAccentHex" FontSize="9" HorizontalAlignment="Center" FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedTextBrush}" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <Button x:Name="SwText" Height="36" Click="OnSwatchClick" Tag="TextColor" Cursor="Hand" BorderThickness="2" BorderBrush="{DynamicResource MutedTextBrush}" Padding="0">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            </ControlTemplate></Button.Template>
                        </Button>
                        <TextBlock x:Name="SwTextLabel" Text="Text" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="SwTextHex" FontSize="9" HorizontalAlignment="Center" FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedTextBrush}" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <Button x:Name="SwMuted" Height="36" Click="OnSwatchClick" Tag="MutedTextColor" Cursor="Hand" BorderThickness="2" BorderBrush="{DynamicResource MutedTextBrush}" Padding="0">
                            <Button.Template><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            </ControlTemplate></Button.Template>
                        </Button>
                        <TextBlock x:Name="SwMutedLabel" Text="Muted" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock x:Name="SwMutedHex" FontSize="9" HorizontalAlignment="Center" FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedTextBrush}" Opacity="0.7"/>
                    </StackPanel>
                </Grid>

                <!-- v1.24: muted visibility slider now spans the strip width with
                     its own label (was an unlabeled stub under the removed Muted
                     swatch). Still does NOT mark the palette as Custom; it's a
                     render-time multiplier, not a hex change. -->
                <Grid Height="18" Margin="0,2,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Muted text visibility" Style="{StaticResource FL}"
                               Margin="0" VerticalAlignment="Center"/>
                    <Slider x:Name="MutedContrastSlider" Grid.Column="2"
                            Style="{StaticResource Slim}"
                            Minimum="0.5" Maximum="1.6" SmallChange="0.05" LargeChange="0.1"
                            VerticalAlignment="Center"
                            ValueChanged="OnMutedContrastChanged"
                            ToolTip="Adjust muted text visibility (does not change palette colors)"/>
                </Grid>

                <!-- Hidden hex boxes for code-behind -->
                <TextBox x:Name="BackgroundColorBox" Visibility="Collapsed" LostFocus="OnColorBoxChanged"/>
                <TextBox x:Name="TileColorBox"       Visibility="Collapsed" LostFocus="OnColorBoxChanged"/>
                <TextBox x:Name="AccentColorBox"     Visibility="Collapsed" LostFocus="OnColorBoxChanged"/>
                <TextBox x:Name="TextColorBox"       Visibility="Collapsed" LostFocus="OnColorBoxChanged"/>
                <TextBox x:Name="MutedTextColorBox"  Visibility="Collapsed" LostFocus="OnColorBoxChanged"/>

                <!-- v1.13: Font section (was "Font Sizes" in v1.12). Adds family
                     dropdowns for Primary/Secondary/Indicator plus sync + dice
                     toggles. The size sliders are kept at the bottom of the section. -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Font" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Pick fonts for Primary numbers, Secondary labels, and Indicators (units). Toggle 'Sync' to lock all three together. Sizes nudge the chosen font up or down." FontSize="11" MaxWidth="260" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- v1.19: Font section reordered per user request to:
                     header > 2 toggles > font dropdowns > size sliders.
                     The toggles control mirror behavior so showing them above
                     the dropdowns makes that influence obvious. -->

                <!-- Sync + dice-randomize-fonts toggles -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" x:Name="SyncFontsCheck" Content="Sync fonts"
                              Style="{StaticResource SW}" VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              Checked="OnSyncFontsToggle" Unchecked="OnSyncFontsToggle"
                              ToolTip="When on, changing Primary font also sets Secondary and Indicator to the same font."/>
                    <CheckBox Grid.Column="2" x:Name="RandomizeFontsCheck" Content="Allow random fonts with 🎲 button"
                              Style="{StaticResource SW}" VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              Checked="OnRandomizeFontsToggle" Unchecked="OnRandomizeFontsToggle"
                              ToolTip="When on, the 🎲 button also picks random fonts in addition to theme + skin."/>
                </Grid>

                <!-- Font family dropdowns: Primary / Secondary / Indicators -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Primary font" Style="{StaticResource FL}"/>
                        <ComboBox x:Name="PrimaryFontCombo" SelectionChanged="OnPrimaryFontFamilyChanged" Height="22" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Secondary font" Style="{StaticResource FL}"/>
                        <ComboBox x:Name="SecondaryFontCombo" SelectionChanged="OnSecondaryFontFamilyChanged" Height="22" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Indicator font" Style="{StaticResource FL}"/>
                        <ComboBox x:Name="IndicatorFontCombo" SelectionChanged="OnIndicatorFontFamilyChanged" Height="22" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Font size sliders (moved into the Font section) -->
                <TextBlock Text="Font sizes" Style="{StaticResource FL}" Margin="0,0,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Primary" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                            <Slider x:Name="PrimaryFontSlider" Style="{StaticResource Slim}" Minimum="-5" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnPrimaryFontChanged"/>
                            <TextBlock x:Name="PrimaryFontLabel" Grid.Column="1" Style="{StaticResource FL}" HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Secondary" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SecondaryFontSlider" Style="{StaticResource Slim}" Minimum="-5" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnSecondaryFontChanged"/>
                            <TextBlock x:Name="SecondaryFontLabel" Grid.Column="1" Style="{StaticResource FL}" HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Indicators" Style="{StaticResource FL}"/>
                        <Grid Height="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                            <Slider x:Name="IndicatorFontSlider" Style="{StaticResource Slim}" Minimum="-5" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="OnIndicatorFontChanged"/>
                            <TextBlock x:Name="IndicatorFontLabel" Grid.Column="1" Style="{StaticResource FL}" HorizontalAlignment="Right" Margin="0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Remote Monitoring -->
                <!-- v1.25.2: the whole section body (TCP feed + handshake + remote
                     devices) is collapsed by default behind RemoteMonitoringToggle.
                     Keeps the right column short for the common case where remote
                     monitoring is unused. -->
                <StackPanel x:Name="RemoteMonitoringSection">
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Remote Monitoring" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Share this machine's sensor data over your local network. Others connect using the key below." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <CheckBox x:Name="RemoteMonitoringToggle" Style="{StaticResource SW}"
                              Content="" Margin="10,0,0,0" VerticalAlignment="Center"
                              Checked="OnRemoteMonitoringToggle" Unchecked="OnRemoteMonitoringToggle"
                              ToolTip="Show remote monitoring options"/>
                </StackPanel>
                    <StackPanel x:Name="RemoteMonitoringBody" Visibility="Collapsed">
                    <CheckBox x:Name="TcpEnabledCheck" Content="Enable TCP sensor feed (port 5199)"
                              Style="{StaticResource SW}"
                              Checked="OnTcpEnabledToggle" Unchecked="OnTcpEnabledToggle"/>
                    <TextBlock Text="Handshake key" Style="{StaticResource FL}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="HandshakeKeyBox" Width="260" IsReadOnly="True"
                                 Style="{StaticResource HexInput}" FontSize="10"/>
                        <Button Content="Copy" Style="{StaticResource InlineBtn}" Margin="8,0,0,0" Click="OnCopyHandshakeKey"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Regenerate Key…" Style="{StaticResource InlineBtn}" Click="OnRegenerateKey"/>
                        <TextBlock x:Name="RegenerateStatus" Style="{StaticResource FL}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="⚠ Regenerating disconnects all remote devices."
                               Style="{StaticResource FL}" Opacity="0.45" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Remote Devices -->
                <StackPanel x:Name="RemoteDevicesSection"
                            Visibility="{Binding IsChecked, ElementName=RemoteMonitoringToggle, Converter={StaticResource BoolVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                    <TextBlock Text="Remote Devices" Style="{StaticResource SH}" Margin="0"/>
                    <Border Width="14" Height="14" CornerRadius="7" Margin="5,0,0,0"
                            Background="{DynamicResource MutedTextBrush}" Opacity="0.4"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="0">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="Monitor other machines running fluidMonitor. Add them using their IP and handshake key." FontSize="11" MaxWidth="240" TextWrapping="Wrap" Padding="2"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                    <TextBlock x:Name="DeviceCountLabel" Style="{StaticResource FL}" Margin="0,0,0,4"/>

                    <ItemsControl x:Name="DeviceList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type proto:RemoteDevice}">
                                <Border Background="{DynamicResource TileBrush}"
                                        Padding="10,6" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="22"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="IndianRed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#FF3DC98A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Grid.Column="1" Text="{Binding Device.Name}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Device.IpAddress}"
                                                   Style="{StaticResource FL}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0"/>
                                        <Button Grid.Column="3" Content="Popout" Style="{StaticResource InlineBtn}"
                                                Padding="4,2" Margin="0,0,3,0" Tag="{Binding Device.Id}" Click="OnDevicePopout"/>
                                        <Button Grid.Column="4" Content="✕" Style="{StaticResource InlineBtn}"
                                                Padding="2,2" Foreground="IndianRed" FontWeight="Bold"
                                                Tag="{Binding Device.Id}" Click="OnDeviceRemove"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add device form -->
                    <Border x:Name="AddDevicePanel" Background="{DynamicResource TileBrush}" Padding="12,8" Margin="0,3,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Add remote device" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Name" Style="{StaticResource FL}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="NewDeviceName" Style="{StaticResource LineInput}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="IP address" Style="{StaticResource FL}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="NewDeviceIp" Style="{StaticResource LineInput}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Handshake key" Style="{StaticResource FL}" Margin="0,6,0,2"/>
                            <TextBox x:Name="NewDeviceKey" Style="{StaticResource HexInput}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Test"   Style="{StaticResource InlineBtn}" Margin="0,0,4,0" Click="OnTestConnection"/>
                                <Button Content="Save"   Style="{StaticResource InlineBtn}" Margin="0,0,4,0" Click="OnSaveDevice"/>
                                <Button Content="Cancel" Style="{StaticResource InlineBtn}" Click="OnCancelAddDevice"/>
                                <TextBlock x:Name="TestStatus" Style="{StaticResource FL}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button x:Name="AddDeviceBtn" Content="+ Add Device" Style="{StaticResource InlineBtn}"
                            Margin="0,6,0,0" HorizontalAlignment="Left" Click="OnShowAddDevice"/>
                </StackPanel>

                <!-- v1.25.2: Sensors — CPU temperature opt-in / opt-out. Moved to
                     the right column under Add Device so it's visible without
                     scrolling the long left column. Attention border + arrow
                     pulse when unconfigured and not dismissed (RefreshCpuTempRow). -->
                <StackPanel x:Name="SensorsSection" Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,16,0,8">
                    <TextBlock Text="Sensors" Style="{StaticResource SH}" Margin="0"/>
                    <TextBlock x:Name="CpuTempAttentionArrow" Text=" ←"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
                <Border x:Name="CpuTempAttentionBorder"
                        Background="{DynamicResource TileBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="0"
                        CornerRadius="6" Padding="11,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="CPU temperature" Style="{StaticResource FL}" Margin="0,0,0,2"/>
                            <TextBlock x:Name="CpuTempStatusLabel" FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextWrapping="Wrap" MaxWidth="220"
                                       Text="Off — showing load only. Set up to add temperature."/>
                        </StackPanel>
                        <Button x:Name="CpuTempActionBtn" Grid.Column="1" Click="OnCpuTempAction"
                                VerticalAlignment="Center" MinWidth="80" Margin="0,0,6,0"
                                Cursor="Hand" FontSize="12"
                                Foreground="White" Content="Set up">
                            <!-- v1.25.16: explicit ControlTemplate so the AccentBrush
                                 background actually shows. The default Aero Button
                                 template overlays its own chrome background, which
                                 left this button stuck on the system blue instead of
                                 following the theme accent. -->
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="4" Padding="12,5"
                                            Background="{DynamicResource AccentBrush}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="2" Content="Dismiss" Style="{StaticResource InlineBtn}"
                                VerticalAlignment="Center" Click="OnDismissSensors"
                                ToolTip="Hide this section. Access temperature setup via the (i) icon next to Tiles."/>
                    </Grid>
                </Border>
                </StackPanel>

                <!-- v1.0.6: Updates — moved from standalone window into Settings -->
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Updates" Style="{StaticResource SH}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource TileBrush}" CornerRadius="6" Padding="11,9">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Current version" FontSize="10"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="CurrentVersionLabel" FontSize="10"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <DockPanel x:Name="NewVersionRow" Visibility="Collapsed" Margin="0,0,0,6">
                                <TextBlock Text="New version" FontSize="10"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="NewVersionLabel" FontSize="10"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Border x:Name="ChangelogBox" Visibility="Collapsed"
                                    Background="{DynamicResource BackgroundBrush}"
                                    CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="What's new:" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="ChangelogText" FontSize="9"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap" MaxHeight="100"/>
                                </StackPanel>
                            </Border>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <RadioButton x:Name="UpdateAutoBtn" Content="Auto"
                                                 Style="{StaticResource UpdateModeRadio}"
                                                 Click="OnUpdateModeChanged" Margin="0,0,3,0"/>
                                    <RadioButton x:Name="UpdateManualBtn" Content="Manual"
                                                 Style="{StaticResource UpdateModeRadio}"
                                                 IsChecked="True"
                                                 Click="OnUpdateModeChanged" Margin="0,0,3,0"/>
                                    <RadioButton x:Name="UpdateOffBtn" Content="Off"
                                                 Style="{StaticResource UpdateModeRadio}"
                                                 Click="OnUpdateModeChanged"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="LaterBtn" Content="Later"
                                            Style="{StaticResource BottomBar}"
                                            Click="OnUpdateLater" Visibility="Collapsed"
                                            FontSize="9" Padding="8,4" Margin="0,0,4,0"/>
                                    <Button x:Name="DownloadBtn" Content="Download and install"
                                            Style="{StaticResource BottomBarPrimary}"
                                            Click="OnUpdateDownload" Visibility="Collapsed"
                                            FontSize="9" Padding="8,4"/>
                                    <Button x:Name="CheckNowBtn" Content="Check now"
                                            Style="{StaticResource BottomBar}"
                                            Click="OnCheckNow" FontSize="9" Padding="8,4"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock x:Name="UpdateStatusText" FontSize="9"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="LastCheckedLabel" Text="Last checked: never"
                                       FontSize="8" Foreground="{DynamicResource MutedTextBrush}"
                                       Opacity="0.5" HorizontalAlignment="Right"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>

            <Popup x:Name="ColorPopup" Grid.Column="0" Grid.ColumnSpan="3"
                   StaysOpen="False" AllowsTransparency="True"
                   Placement="MousePoint" PopupAnimation="Fade">
                <local:ColorPicker x:Name="PickerControl"/>
            </Popup>

        </Grid>
        </ScrollViewer>

    </DockPanel>
    </Grid>

</Window>
